# .env.example — copy this to .env (or paste into Dockge's stack.env) and fill in your values.
# All variables marked "Required" must be set before starting the container.

# ── Required: GitHub personal access tokens ───────────────────────────────────
# Both tokens need "repo" scope (read + write).
# Generate at: GitHub → Settings → Developer settings → Personal access tokens
IDEAS_WORKBENCH_GIT_TOKEN=ghp_xxx        # token for your private papers repo
PRESSROOM_PUBS_GIT_TOKEN=ghp_xxx         # token for your public pubs repo

# ── Required: Repository names (owner/repo format) ───────────────────────────
IDEAS_WORKBENCH_REPO=you/ideas-workbench  # your private papers/ideas repo
PRESSROOM_PUBS_REPO=you/pressroom-pubs    # your public published-outputs repo

# ── Required: App login credentials ──────────────────────────────────────────
APP_USER=changeme
APP_PASSWORD=changeme

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme

# ── Required: Author info ─────────────────────────────────────────────────────
# Used as fallback defaults when zz-pressroom/author.yaml doesn't exist yet.
# After first login, edit author.yaml in Obsidian instead of changing these.
AUTHOR_NAME=Your Name
AUTHOR_EMAIL=you@example.com
AUTHOR_GITHUB=yourusername

# ── Optional: Advanced settings (safe to omit — defaults shown) ───────────────

# Which branch to read/write across all three repos (default: main)
# GITHUB_BRANCH=main

# PDF rendering engine: "pandoc" uses XeLaTeX; "sile" is an alternative typesetter
# PDF_ENGINE=pandoc

# Login session length in minutes (default: 480 = 8 hours)
# JWT_EXPIRY_MINUTES=480

# The pressroom source repo — used to fetch bundled templates at runtime.
# Only change this if you have forked pressroom under a different name.
# PRESSROOM_REPO=zzpanic/pressroom
