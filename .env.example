# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to stack.env and fill in the real values.
# stack.env is loaded by docker-compose.yml (via env_file).
# Never commit stack.env to git — it contains real tokens.
#
# GitHub tokens must be classic personal access tokens with "repo" scope
# (read + write access to repository contents).
# Generate them at: https://github.com/settings/tokens
# ─────────────────────────────────────────────────────────────────────────────


# ── Ideas Workbench ───────────────────────────────────────────────────────────
# Your private repo that holds ideas, drafts, and publish folders.

IDEAS_WORKBENCH_GIT_USER=zzpanic
IDEAS_WORKBENCH_GIT_TOKEN=ghp_xxxx
IDEAS_WORKBENCH_REPO=zzpanic/ideas-workbench


# ── Pressroom Pubs ────────────────────────────────────────────────────────────
# Your public repo that receives versioned published snapshots.

PRESSROOM_PUBS_GIT_USER=zzpanic
PRESSROOM_PUBS_GIT_TOKEN=ghp_xxxx
PRESSROOM_PUBS_REPO=zzpanic/pressroom-pubs


# ── Pressroom App Repo ────────────────────────────────────────────────────────
# The public repo containing this app (used to fetch templates at runtime).
# You probably don't need to change this.

PRESSROOM_REPO=zzpanic/pressroom


# ── Git Branch ────────────────────────────────────────────────────────────────
# Which branch to read from and write to. Almost certainly "main".

GITHUB_BRANCH=main


# ── App Authentication ────────────────────────────────────────────────────────
# Login credentials for the Pressroom web UI.
# Change these before exposing the app to any network.

APP_USER=admin
APP_PASSWORD=pressroom
