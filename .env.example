# GitHub tokens
IDEAS_WORKBENCH_GIT_TOKEN=ghp_xxx        # token with repo access to your papers repo
PRESSROOM_PUBS_GIT_TOKEN=ghp_xxx         # token with repo access to your pubs repo

# Repository names
IDEAS_WORKBENCH_REPO=you/ideas-workbench  # your papers repo
PRESSROOM_PUBS_REPO=you/pressroom-pubs    # your published outputs repo

# App authentication
APP_USER=changeme
APP_PASSWORD=changeme

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme

# Author info
AUTHOR_NAME=Your Name
AUTHOR_EMAIL=you@example.com
AUTHOR_GITHUB=yourusername
